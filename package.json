{
  "name": "md-editor",
  "private": true,
  "version": "0.1.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:build": "tauri build",
    "tauri:build:windows": "tauri build",
    "tauri:build:windows:cross": "tauri build --runner cargo-xwin --target x86_64-pc-windows-msvc --bundles nsis",
    "tauri:build:linux:deb-rpm": "tauri build --bundles deb,rpm",
    "tauri:build:mac": "tauri build",
    "tauri:build:mac:arm": "tauri build --target aarch64-apple-darwin --bundles dmg",
    "tauri:build:mac:intel": "tauri build --target x86_64-apple-darwin --bundles dmg",
    "tauri:build:mac:universal": "tauri build --target universal-apple-darwin"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2",
    "marked": "^18.0.5",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "typescript": "~5.6.2",
    "vite": "^6.0.3"
  }
}
