{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MDEditor",
  "version": "0.1.3",
  "identifier": "me.anfu.md-editor",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "MD Editor",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost data: blob: http: https:; media-src 'self' asset: http://asset.localhost data: blob: http: https:; connect-src 'self' ipc: http://ipc.localhost http: https:",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "shortDescription": "轻量 Markdown 编辑器",
    "longDescription": "基于 Tauri 的 Markdown 编辑器，支持实时预览、文件夹浏览与分屏编辑。",
    "copyright": "Copyright © 2026 anfu",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown"],
        "name": "Markdown Document",
        "description": "Markdown 文档",
        "mimeType": "text/markdown",
        "role": "Editor",
        "rank": "Default"
      }
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "bundleName": "MD Editor",
      "entitlements": "./Entitlements.plist",
      "infoPlist": "./Info.plist",
      "hardenedRuntime": true,
      "dmg": {
        "appPosition": { "x": 180, "y": 170 },
        "applicationFolderPosition": { "x": 480, "y": 170 },
        "windowSize": { "width": 660, "height": 400 }
      }
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "template": "windows/installer.nsi"
      },
      "wix": {
        "language": "zh-CN"
      }
    }
  }
}
