{
  "plugin": {
    "id": "cos-upload",
    "name": "COS 文件上传",
    "version": "1.0.0",
    "description": "通过命令行将本地文件上传到腾讯云 COS",
    "author": "zeroerr",
    "type": "cli",
    "enabled": true,
    "binary": {
      "path": "upload.exe",
      "platforms": {
        "windows": "upload.exe",
        "linux": "upload",
        "darwin": "upload"
      }
    },
    "invoke": {
      "config_mapping": {
        "access_key_id": "id",
        "access_key_secret": "secret",
        "bucket": "b",
        "region": "r",
        "endpoint": "endpoint"
      }
    },
    "action": {
      "upload": {
        "id": "upload",
        "name": "上传文件",
        "description": "上传本地文件到 COS Bucket",
        "params": {
          "file": {
            "type": "file",
            "required": true,
            "description": "待上传的本地文件路径",
            "cli_flag": "f",
            "cli_value_prefix": "@"
          },
          "key": {
            "type": "string",
            "required": false,
            "description": "COS 对象键；不填则使用文件名",
            "cli_flag": "key"
          }
        }
      }
    }
  },
  "cos": {
    "access_key_id": "YOUR_SECRET_ID",
    "access_key_secret": "YOUR_SECRET_KEY",
    "bucket": "your-bucket-name",
    "region": "ap-guangzhou",
    "endpoint": ""
  },
  "examples": [
    "upload.exe -id \"YOUR_SECRET_ID\" -secret \"YOUR_SECRET_KEY\" -b \"your-bucket-name\" -r \"ap-guangzhou\" -f @c:/img.png",
    "upload.exe -id \"YOUR_SECRET_ID\" -secret \"YOUR_SECRET_KEY\" -b \"your-bucket-name\" -r \"ap-guangzhou\" -f @c:/img.png -key \"images/avatar.png\"",
    "upload.exe -id \"YOUR_SECRET_ID\" -secret \"YOUR_SECRET_KEY\" -b \"your-bucket-name\" -r \"ap-guangzhou\" -endpoint \"cos.ap-guangzhou.myqcloud.com\" -f @c:/img.png"
  ]
}
